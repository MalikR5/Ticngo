<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.ticngo.controller.ClientFormController"
      spacing="14" prefWidth="420" styleClass="dialog-card">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <Label text="Client" styleClass="form-title"/>
    <Separator/>

    <VBox spacing="6">
        <Label text="Nom *" styleClass="form-label"/>
        <TextField fx:id="nomField" promptText="ex: Martin" styleClass="form-input"/>
    </VBox>
    <VBox spacing="6">
        <Label text="Prénom *" styleClass="form-label"/>
        <TextField fx:id="prenomField" promptText="ex: Sophie" styleClass="form-input"/>
    </VBox>
    <VBox spacing="6">
        <Label text="Email *" styleClass="form-label"/>
        <TextField fx:id="emailField" promptText="ex: sophie@email.fr" styleClass="form-input"/>
    </VBox>
    <VBox spacing="6">
        <Label text="Téléphone" styleClass="form-label"/>
        <TextField fx:id="telField" promptText="ex: 06 12 34 56 78" styleClass="form-input"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#onCancel"/>
        <Button text="✓ Enregistrer" styleClass="btn-primary" onAction="#onSave"/>
    </HBox>
</VBox>
