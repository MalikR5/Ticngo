<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.ticngo.controller.ClientListController"
      spacing="16">

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Rechercher (nom, email...)"
                   styleClass="search-field" prefWidth="280"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" styleClass="count-label"/>
        <Button text="+ Nouveau client" styleClass="btn-primary" onAction="#onNouveauClient"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="clientTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colNom"    text="Nom"       prefWidth="140"/>
                <TableColumn fx:id="colPrenom" text="Prénom"    prefWidth="130"/>
                <TableColumn fx:id="colEmail"  text="Email"     prefWidth="220"/>
                <TableColumn fx:id="colTel"    text="Téléphone" prefWidth="130"/>
                <TableColumn fx:id="colDate"   text="Inscription" prefWidth="110"/>
                <TableColumn fx:id="colActions" text="Actions"  prefWidth="150"/>
            </columns>
            <placeholder><Label text="Aucun client"/></placeholder>
        </TableView>
    </VBox>
</VBox>
